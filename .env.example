# ================================================================================
# NEXUS — Environment Variables Template
# ================================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in ALL required values
# 3. Never commit .env.local to version control
# ================================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
# REQUIRED: Change to a long random secret before deploying
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=nexus-replace-with-cryptographically-random-secret-here

# Token expiry in minutes (default: 1440 = 24 hours)
JWT_EXPIRE_MINUTES=1440

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "true" in production to enable secure cookies and production validations
IS_PRODUCTION=false

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite for development (file-based, no setup required)
DATABASE_URL=sqlite:///./nexus.db

# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/nexus

# ── App URL ───────────────────────────────────────────────────────────────────
# URL where the frontend is hosted (used for OAuth callbacks)
APP_URL=http://localhost:3000

# ── AI Features (Gemini) ──────────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI to configure: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Setup: https://github.com/settings/developers → New OAuth App
# Callback URL to configure: http://localhost:8000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Apple Sign In ─────────────────────────────────────────────────────────────
# Setup: https://developer.apple.com → Certificates, Identifiers & Profiles → Services IDs
# Callback URL to configure: http://localhost:8000/api/auth/apple/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=


# ── Email — Option 1: n8n Webhook (Recommended for development) ───────────────
# Install n8n: npx n8n
# Create a webhook workflow at http://localhost:5678
# Set the webhook URL here to route email automation through n8n
# Payload fields: { type, to, name, otp }
N8N_WEBHOOK_URL=

# ── Email — Option 2: Direct SMTP ────────────────────────────────────────────
# Used as fallback if N8N_WEBHOOK_URL is not set
# Gmail App Password setup: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=no-reply@nexus.app

# ── Resend Email Service ──────────────────────────────────────────────────────
# Used if N8N_WEBHOOK_URL is not set and RESEND_API_KEY is configured
# Get your API key from: https://resend.com
RESEND_API_KEY=

# ── Cloudinary Image Storage ──────────────────────────────────────────────────
# Setup: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Sentry Error Monitoring ───────────────────────────────────────────────────
# Setup: https://sentry.io
SENTRY_DSN=
VITE_SENTRY_DSN=


# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Backend base URL accessible from the browser
VITE_BACKEND_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000
