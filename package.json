{
  "name": "nexus",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others --prefix-colors \"cyan,magenta\" --names \"BACKEND,FRONTEND\" \"node scripts/start-backend.cjs\" \"vite --port=3000 --host=0.0.0.0\"",
    "frontend": "vite --port=3000 --host=0.0.0.0",
    "backend": "node scripts/start-backend.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "echo \"No automated tests configured. Run: npm run lint\" && npm run lint",
    "typecheck": "tsc --noEmit",
    "start": "npm run dev"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/react": "^10.66.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^6.30.4",
    "socket.io-client": "^4.8.3",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^8.0.3"
  }
}
